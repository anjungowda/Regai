# Database
DATABASE_URL="postgresql://user:password@localhost:5432/regshield?schema=public"

# Authentication
# Run `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"` to generate these
JWT_SECRET="your_jwt_secret_here_make_it_long_and_secure"
JWT_REFRESH_SECRET="your_jwt_refresh_secret_here"
COOKIE_DOMAIN="localhost"

# Frontend / CORS
FRONTEND_URL="http://localhost:5173"

# AWS Configuration (S3 for Evidence, SES for Email)
AWS_REGION="eu-west-2"
AWS_ACCESS_KEY_ID="your_aws_access_key_id"
AWS_SECRET_ACCESS_KEY="your_aws_secret_access_key"
S3_EVIDENCE_BUCKET="regshield-evidence-dev"
SES_FROM_EMAIL="noreply@regshield.ai"
SES_ADMIN_EMAIL="info@regshield.ai"

# Stripe Billing
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Application
NODE_ENV="development"
PORT="3000"
