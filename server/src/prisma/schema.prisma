generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organisation {
  id                 String    @id @default(uuid())
  name               String
  displayName        String?
  orgType            String?   // Fintech / Payment Company / EMI / Neobank / Other
  regulatoryFramework String?
  complianceTeamSize String?
  planType           String    @default("standard")
  isActive           Boolean   @default(true)
  billingEmail       String?
  stripeCustomerId   String?   @unique
  logoUrl            String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  users              User[]
  cases              Case[]
  customers          Customer[]
  companies          Company[]
  evidence           Evidence[]
  alerts             Alert[]
  tasks              Task[]
  templates          Template[]
  flags              Flag[]
  subscription       Subscription?
  auditLogs          AuditLog[]
  riskAssessments    RiskAssessment[]
}

model User {
  id                 String    @id @default(uuid())
  orgId              String
  email              String    @unique
  passwordHash       String
  fullName           String
  role               String    // admin / compliance_manager / analyst / reviewer / auditor
  isActive           Boolean   @default(true)
  onboardingComplete Boolean   @default(false)
  failedLoginAttempts Int      @default(0)
  lockedUntil        DateTime?
  lastLogin          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  org                Organisation @relation(fields: [orgId], references: [id])
  casesAssigned      Case[]       @relation("AssignedCases")
  casesReviewing     Case[]       @relation("ReviewedCases")
  casesCreated       Case[]       @relation("CreatedCases")
  notes              CaseNote[]
  tasksAssigned      Task[]       @relation("TasksAssigned")
  tasksCreated       Task[]       @relation("TasksCreated")
  auditLogs          AuditLog[]
  refreshTokens      RefreshToken[]
  evidenceUploaded   Evidence[]
  alertsCreated      Alert[]
  flagsRaised        Flag[]
  riskAssessments    RiskAssessment[]
}

model RefreshToken {
  id                 String    @id @default(uuid())
  userId             String
  token              String    @unique
  expiresAt          DateTime
  createdAt          DateTime  @default(now())
  isRevoked          Boolean   @default(false)

  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Case {
  id                  String    @id @default(uuid())
  caseRef             String    @unique  // format RS-YYYY-NNNN
  orgId               String
  caseType            String    // onboarding_review / kyb_review ...
  riskLevel           String    // low / medium / high / critical
  status              String    @default("new") // new / in_review / escalated / pending_review / closed
  priority            String    @default("normal") // normal / urgent
  description         String?   @db.Text
  assignedToId        String?
  reviewerId          String?
  createdById         String
  customerId          String?
  companyId           String?
  slaDeadline         DateTime
  closedAt            DateTime?
  decisionOutcome     String?
  decisionRationale   String?   @db.Text
  decisionBy          String?
  decisionAt          DateTime?
  riskScoreAtDecision Int?
  ddLevelApplied      String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  org                 Organisation @relation(fields: [orgId], references: [id])
  assignedTo          User?        @relation("AssignedCases", fields: [assignedToId], references: [id])
  reviewer            User?        @relation("ReviewedCases", fields: [reviewerId], references: [id])
  createdBy           User         @relation("CreatedCases", fields: [createdById], references: [id])
  customer            Customer?    @relation(fields: [customerId], references: [id])
  company             Company?     @relation(fields: [companyId], references: [id])
  notes               CaseNote[]
  evidence            Evidence[]
  tasks               Task[]
  alerts              Alert[]
  flags               Flag[]
  riskAssessments     RiskAssessment[]
}

model Customer {
  id                  String    @id @default(uuid())
  orgId               String
  fullName            String
  dateOfBirth         DateTime?
  nationality         String?
  countryOfResidence  String?
  address             String?   @db.Text
  occupation          String?
  sourceOfFunds       String?
  idVerified          Boolean   @default(false)
  isPep               Boolean   @default(false)
  sanctionsHit        String    @default("none") // none / potential / confirmed
  adverseMedia        Boolean   @default(false)
  riskRating          String?
  riskScore           Int?
  reviewFrequency     String?   // monthly / quarterly / annually / every_3_years
  nextReviewDate      DateTime?
  lastReviewDate      DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  org                 Organisation @relation(fields: [orgId], references: [id])
  cases               Case[]
  flags               Flag[]
  riskAssessments     RiskAssessment[]
}

model Company {
  id                  String    @id @default(uuid())
  orgId               String
  companyName         String
  registrationNumber  String?
  sicCode             String?
  jurisdiction        String?
  countryOfIncorp     String?
  directors           Json?
  uboPscDetails       Json?
  expectedTurnover    String?
  sourceOfFunds       String?
  riskScore           Int?
  riskRating          String?
  nextReviewDate      DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  org                 Organisation @relation(fields: [orgId], references: [id])
  cases               Case[]
  flags               Flag[]
  riskAssessments     RiskAssessment[]
}

model CaseNote {
  id                  String    @id @default(uuid())
  caseId              String
  authorId            String
  content             String    @db.Text
  isInternal          Boolean   @default(false)
  createdAt           DateTime  @default(now())

  case                Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  author              User      @relation(fields: [authorId], references: [id])
}

model Evidence {
  id                  String    @id @default(uuid())
  caseId              String?
  orgId               String
  fileName            String
  fileType            String
  fileSize            Int
  s3Key               String
  s3Bucket            String
  category            String    // identity / bank_statement / invoice / contract / corporate / regulatory / other
  verificationStatus  String    @default("pending") // pending / verified / rejected
  version             Int       @default(1)
  supersededById      String?
  isDeleted           Boolean   @default(false)
  deletedBy           String?
  deletedAt           DateTime?
  uploadedBy          String
  uploadedAt          DateTime  @default(now())

  org                 Organisation @relation(fields: [orgId], references: [id])
  case                Case?        @relation(fields: [caseId], references: [id], onDelete: SetNull)
  uploader            User         @relation(fields: [uploadedBy], references: [id])
}

model Alert {
  id                  String    @id @default(uuid())
  orgId               String
  caseId              String?
  transactionId       String?
  amount              Decimal?  @db.Decimal(12, 2)
  currency            String?
  originCountry       String?
  destinationCountry  String?
  transactionDate     DateTime?
  riskScore           Int?
  triggerRule         String?
  alertReason         String?   @db.Text
  status              String    @default("open") // open / under_review / resolved / escalated
  createdBy           String
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  org                 Organisation @relation(fields: [orgId], references: [id])
  case                Case?        @relation(fields: [caseId], references: [id], onDelete: SetNull)
  creator             User         @relation(fields: [createdBy], references: [id])
}

model Task {
  id                  String    @id @default(uuid())
  caseId              String
  orgId               String
  title               String
  description         String?   @db.Text
  assignedToId        String
  createdById         String
  dueDate             DateTime
  priority            String    @default("normal") // low / normal / high
  isComplete          Boolean   @default(false)
  completedAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  org                 Organisation @relation(fields: [orgId], references: [id])
  case                Case         @relation(fields: [caseId], references: [id], onDelete: Cascade)
  assignedTo          User         @relation("TasksAssigned", fields: [assignedToId], references: [id])
  createdBy           User         @relation("TasksCreated", fields: [createdById], references: [id])
}

model AuditLog {
  id                  String    @id @default(uuid())
  orgId               String
  userId              String
  userFullName        String    // denormalised
  userRole            String    // denormalised
  actionType          String
  entityType          String    // case / evidence / note / task / customer / company / alert / user / organisation
  entityId            String?
  detail              Json?
  ipAddress           String?
  userAgent           String?
  createdAt           DateTime  @default(now())

  org                 Organisation @relation(fields: [orgId], references: [id])
  user                User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([orgId, createdAt])
  @@index([entityId])
}

model Flag {
  id                  String    @id @default(uuid())
  orgId               String
  caseId              String?
  customerId          String?
  companyId           String?
  flagType            String    // customer_risk / transaction_risk / operational_risk
  flagCategory        String    // pep / sanctions / adverse_media ...
  severity            String    // low / medium / high / critical
  status              String    @default("open") // open / under_review / resolved
  description         String?   @db.Text
  raisedById          String
  raisedAt            DateTime  @default(now())
  resolvedById        String?
  resolvedAt          DateTime?

  org                 Organisation @relation(fields: [orgId], references: [id])
  case                Case?        @relation(fields: [caseId], references: [id])
  customer            Customer?    @relation(fields: [customerId], references: [id])
  company             Company?     @relation(fields: [companyId], references: [id])
  raisedBy            User         @relation(fields: [raisedById], references: [id])
}

model RiskAssessment {
  id                        String    @id @default(uuid())
  orgId                     String
  customerId                String?
  companyId                 String?
  caseId                    String?
  assessedById              String
  countryScore              Int
  occupationScore           Int
  sourceOfFundsScore        Int
  pepScore                  Int
  sanctionsScore            Int
  transactionVolumeScore    Int
  relationshipDurationScore Int
  adverseMediaScore         Int
  totalScore                Int
  riskClassification        String    // low / medium / high / critical
  ddRecommendation          String    // sdd / standard / edd / edd_mlro
  notes                     String?   @db.Text
  createdAt                 DateTime  @default(now())

  org                       Organisation @relation(fields: [orgId], references: [id])
  customer                  Customer?    @relation(fields: [customerId], references: [id])
  company                   Company?     @relation(fields: [companyId], references: [id])
  case                      Case?        @relation(fields: [caseId], references: [id])
  assessedBy                User         @relation(fields: [assessedById], references: [id])
}

model Template {
  id                  String    @id @default(uuid())
  orgId               String?   // null = global, set = custom
  templateName        String
  templateType        String    // policy / assessment / report / checklist / regulatory
  description         String?   @db.Text
  contentHtml         String    @db.Text
  isCustom            Boolean   @default(false)
  isActive            Boolean   @default(true)
  createdById         String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  org                 Organisation? @relation(fields: [orgId], references: [id])
}

model Subscription {
  id                  String    @id @default(uuid())
  orgId               String    @unique
  stripeSubscriptionId String?  @unique
  planName            String    // standard / professional
  status              String    // trialing / active / past_due / cancelled / unpaid
  trialEndsAt         DateTime?
  currentPeriodEnd    DateTime?
  cancelAtPeriodEnd   Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  org                 Organisation @relation(fields: [orgId], references: [id])
}

model ContactSubmission {
  id                  String    @id @default(uuid())
  fullName            String
  email               String
  companyName         String
  jobTitle            String?
  message             String    @db.Text
  howHeard            String?
  isRead              Boolean   @default(false)
  submittedAt         DateTime  @default(now())
}

model DemoRequest {
  id                  String    @id @default(uuid())
  fullName            String
  email               String
  companyName         String
  jobTitle            String
  teamSize            String
  biggestChallenge    String    @db.Text
  preferredDate       DateTime
  preferredTimeSlot   String
  howHeard            String?
  isContacted         Boolean   @default(false)
  submittedAt         DateTime  @default(now())
}

model Notification {
  id                  String    @id @default(uuid())
  userId              String
  orgId               String
  title               String
  body                String    @db.Text
  type                String
  entityId            String?
  entityType          String?
  isRead              Boolean   @default(false)
  createdAt           DateTime  @default(now())
}

model PasswordResetToken {
  id                  String    @id @default(uuid())
  userId              String
  tokenHash           String
  expiresAt           DateTime
  isUsed              Boolean   @default(false)
  createdAt           DateTime  @default(now())
}
